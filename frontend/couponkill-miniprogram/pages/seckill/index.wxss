.page { padding: 24rpx; }
.banner {
  background: #ff4757;
  color: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  font-size: 28rpx;
}
.card {
  background: #fff;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.name { font-weight: 600; }
.meta { color: #666; margin-top: 8rpx; font-size: 24rpx; }
.hint { color: #999; padding: 24rpx 0; }
