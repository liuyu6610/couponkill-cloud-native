<view class="page">
  <view class="banner">秒杀专区 · 对齐 /api/v1/order/seckill</view>
  <view wx:if="{{isLoading}}" class="hint">加载中...</view>
  <block wx:for="{{coupons}}" wx:key="id">
    <view class="card" data-id="{{item.id}}" bindtap="goDetail">
      <view class="name">{{item.name}}</view>
      <view class="meta">库存 {{item.seckillRemainingStock}} · 开售 {{item.seckillStartAt || '未配置'}}</view>
    </view>
  </block>
  <view wx:if="{{!isLoading && coupons.length===0}}" class="hint">暂无秒杀活动</view>
</view>
