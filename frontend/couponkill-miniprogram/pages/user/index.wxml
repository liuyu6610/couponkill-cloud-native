<view class="page">
  <view wx:if="{{userInfo}}" class="card">
    <view class="name">{{userInfo.username}}</view>
    <view class="meta">用户ID：{{userInfo.id}}</view>
    <view class="meta">手机：{{userInfo.phone || '-'}}</view>
  </view>

  <view class="section-title">最近订单</view>
  <block wx:for="{{recentOrders}}" wx:key="id">
    <view class="card">
      <view>{{item.id}} · {{item.statusText}}</view>
      <view class="meta">券 {{item.couponId}}</view>
    </view>
  </block>
  <view wx:if="{{!isLoading && recentOrders.length===0}}" class="hint">暂无订单</view>

  <button bindtap="goOrders">查看全部订单</button>
  <button type="warn" bindtap="logout">退出登录</button>
</view>
