<view class="page-container">
  <view class="form">
    <input class="input" placeholder="用户名" data-field="username" bindinput="onInputChange" />
    <input class="input" placeholder="手机号" data-field="phone" bindinput="onInputChange" />
    <input class="input" password placeholder="密码（至少6位）" data-field="password" bindinput="onInputChange" />
    <input class="input" password placeholder="确认密码" data-field="confirmPassword" bindinput="onInputChange" />
    <button class="btn" bindtap="register" disabled="{{isLoading}}">
      {{isLoading ? '提交中...' : '注册'}}
    </button>
    <view class="link" bindtap="goLogin">已有账号？去登录</view>
  </view>
</view>
