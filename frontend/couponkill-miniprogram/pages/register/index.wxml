<!--pages/register/index.wxml-->
<view class="page-container">
  <view class="register-container">
    <!-- Logo区域 -->
    <view class="register-logo">
      <view class="logo-icon">🎫</view>
      <view class="logo-text">创建账号</view>
      <view class="logo-subtitle">加入CouponKill，享受更多优惠</view>
    </view>

    <!-- 注册表单 -->
    <view class="register-form">
      <!-- 用户名输入 -->
      <view class="form-item">
        <view class="input-group">
          <input
            class="form-input"
            placeholder="请输入用户名"
            value="{{form.username}}"
            data-field="username"
            bindinput="onInputChange"
          />
        </view>
      </view>

      <!-- 邮箱输入 -->
      <view class="form-item">
        <view class="input-group">
          <input
            class="form-input"
            placeholder="请输入邮箱"
            value="{{form.email}}"
            data-field="email"
            bindinput="onInputChange"
            type="email"
          />
        </view>
      </view>

      <!-- 手机号输入 -->
      <view class="form-item">
        <view class="input-group">
          <input
            class="form-input"
            placeholder="请输入手机号（可选）"
            value="{{form.phone}}"
            data-field="phone"
            bindinput="onInputChange"
            type="number"
          />
        </view>
      </view>

      <!-- 密码输入 -->
      <view class="form-item">
        <view class="input-group">
          <input
            class="form-input"
            placeholder="请输入密码（至少6位）"
            value="{{form.password}}"
            data-field="password"
            bindinput="onInputChange"
            password="{{!passwordVisible}}"
          />
          <view class="password-toggle" bindtap="togglePasswordVisible">
            {{passwordVisible ? '🙈' : '👁️'}}
          </view>
        </view>
      </view>

      <!-- 确认密码输入 -->
      <view class="form-item">
        <view class="input-group">
          <input
            class="form-input"
            placeholder="请再次输入密码"
            value="{{form.confirmPassword}}"
            data-field="confirmPassword"
            bindinput="onInputChange"
            password="{{!confirmPasswordVisible}}"
          />
          <view class="password-toggle" bindtap="toggleConfirmPasswordVisible">
            {{confirmPasswordVisible ? '🙈' : '👁️'}}
          </view>
        </view>
      </view>

      <!-- 注册按钮 -->
      <view class="form-actions">
        <button
          class="btn-register {{isLoading ? 'loading' : 'active'}}"
          bindtap="register"
          disabled="{{isLoading}}"
        >
          <view wx:if="{{!isLoading}}" class="btn-content">
            <view class="btn-text">立即注册</view>
          </view>
          <view wx:if="{{isLoading}}" class="loading-content">
            <view class="loading-spinner"></view>
            <view class="loading-text">注册中...</view>
          </view>
        </button>
      </view>

      <!-- 登录链接 -->
      <view class="login-link">
        <view class="link-text">
          已有账号？
          <text class="link" bindtap="goToLogin">立即登录</text>
        </view>
      </view>
    </view>

    <!-- 注册协议 -->
    <view class="register-agreement">
      <view class="agreement-text">
        注册即表示同意
        <text class="link">《用户协议》</text>
        和
        <text class="link">《隐私政策》</text>
      </view>
    </view>
  </view>
</view>
