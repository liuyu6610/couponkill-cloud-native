/* pages/register/index.wxss */
.page-container {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 40rpx;
}

.register-container {
  width: 100%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

/* Logo区域样式 */
.register-logo {
  text-align: center;
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(135deg, #ff4757, #ff6b7a);
  color: #fff;
}

.logo-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.logo-text {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.logo-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 表单样式 */
.register-form {
  padding: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.input-group {
  position: relative;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  overflow: hidden;
  transition: border-color 0.3s;
}

.input-group:focus-within {
  border-color: #ff4757;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  border: none;
  outline: none;
  font-size: 28rpx;
  color: #333;
}

.password-toggle {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #666;
  padding: 10rpx;
}

/* 注册按钮样式 */
.form-actions {
  margin: 40rpx 0;
}

.btn-register {
  width: 100%;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 0;
  transition: all 0.3s;
}

.btn-register.active {
  background: linear-gradient(135deg, #ff4757, #ff6b7a);
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(255, 71, 87, 0.3);
}

.btn-register.active:active {
  background: linear-gradient(135deg, #ff3742, #ff5a67);
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 10rpx rgba(255, 71, 87, 0.3);
}

.btn-register.loading {
  background: #ccc;
  color: #999;
  cursor: not-allowed;
}

.loading-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #f3f3f3;
  border-top: 3rpx solid #ff4757;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 16rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 登录链接样式 */
.login-link {
  text-align: center;
  margin-bottom: 40rpx;
}

.link-text {
  font-size: 28rpx;
  color: #666;
}

.link {
  color: #ff4757;
  margin-left: 8rpx;
}

/* 注册协议样式 */
.register-agreement {
  text-align: center;
  padding: 0 40rpx 40rpx;
  border-top: 2rpx solid #f0f0f0;
}

.agreement-text {
  font-size: 24rpx;
  color: #999;
}

.link {
  color: #ff4757;
  margin: 0 4rpx;
}
