/* pages/order-detail/index.wxss */
.page-container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 导航栏样式 */
.navbar {
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-back {
  font-size: 32rpx;
  color: #333;
  padding: 10rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  text-align: center;
}

.nav-placeholder {
  width: 60rpx;
}

/* 订单状态卡片样式 */
.status-card {
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.order-status {
  background: #fff;
  padding: 40rpx 30rpx;
  text-align: center;
  position: relative;
}

.order-status.PENDING {
  background: linear-gradient(135deg, #ff9800, #ffb74d);
  color: #fff;
}

.order-status.PAID {
  background: linear-gradient(135deg, #2196f3, #64b5f6);
  color: #fff;
}

.order-status.SHIPPED {
  background: linear-gradient(135deg, #9c27b0, #ba68c8);
  color: #fff;
}

.order-status.DELIVERED {
  background: linear-gradient(135deg, #4caf50, #81c784);
  color: #fff;
}

.order-status.CANCELLED {
  background: linear-gradient(135deg, #f44336, #ef5350);
  color: #fff;
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: bold;
}

/* 信息卡片样式 */
.order-info-card, .goods-card, .logistics-card, .order-actions-card {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.info-header, .goods-header, .logistics-header, .actions-title {
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  border-bottom: 2rpx solid #f0f0f0;
}

/* 订单信息样式 */
.info-content {
  padding: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.info-value.price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4757;
}

/* 商品信息样式 */
.goods-list {
  padding: 30rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.goods-quantity {
  background-color: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.goods-price {
  font-weight: bold;
  color: #ff4757;
}

/* 物流信息样式 */
.logistics-content {
  padding: 30rpx;
}

.logistics-company {
  margin-bottom: 30rpx;
  text-align: center;
}

.company-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.logistics-no {
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.logistics-timeline {
  position: relative;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  position: relative;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 40rpx;
  bottom: -20rpx;
  width: 2rpx;
  background-color: #f0f0f0;
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #ff4757;
  margin-right: 20rpx;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.timeline-content {
  flex: 1;
}

.timeline-desc {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.timeline-time {
  font-size: 24rpx;
  color: #666;
}

/* 订单操作样式 */
.order-actions-card {
  padding-bottom: 40rpx;
}

.actions-title {
  border-bottom: 2rpx solid #f0f0f0;
}

.actions-list {
  padding: 30rpx;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  padding: 20rpx 0;
  transition: all 0.3s;
}

.action-btn.cancel {
  background-color: #fff;
  color: #f44336;
  border: 2rpx solid #f44336;
}

.action-btn.cancel:active {
  background-color: #ffebee;
}

.action-btn.confirm {
  background-color: #fff;
  color: #4caf50;
  border: 2rpx solid #4caf50;
}

.action-btn.confirm:active {
  background-color: #e8f5e8;
}

.action-btn.refund {
  background-color: #fff;
  color: #ff9800;
  border: 2rpx solid #ff9800;
}

.action-btn.refund:active {
  background-color: #fff3e0;
}

/* 加载状态样式 */
.loading-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 120rpx 40rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #ff4757;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
