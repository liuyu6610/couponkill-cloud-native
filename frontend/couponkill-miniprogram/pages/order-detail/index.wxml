<!--pages/order-detail/index.wxml-->
<view class="page-container">
  <!-- 导航栏 -->
  <view class="navbar">
    <view class="nav-back" bindtap="goBack">‹ 返回</view>
    <view class="nav-title">订单详情</view>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <view>加载中...</view>
  </view>

  <!-- 订单详情内容 -->
  <view class="order-detail" wx:if="{{!isLoading && order}}">
    <!-- 订单状态卡片 -->
    <view class="status-card">
      <view class="order-status {{order.status}}">
        <view class="status-icon">{{getStatusIcon(order.status)}}</view>
        <view class="status-text">{{getStatusText(order.status)}}</view>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="order-info-card">
      <view class="info-header">
        <view class="info-title">订单信息</view>
      </view>
      <view class="info-content">
        <view class="info-row">
          <view class="info-label">订单号</view>
          <view class="info-value">{{order.orderNo}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">下单时间</view>
          <view class="info-value">{{formatDate(order.createdAt)}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">支付金额</view>
          <view class="info-value price">¥{{order.paymentAmount}}</view>
        </view>
      </view>
    </view>

    <!-- 商品信息 -->
    <view class="goods-card">
      <view class="goods-header">
        <view class="goods-title">商品信息</view>
      </view>
      <view class="goods-list">
        <view class="goods-item" wx:for="{{order.orderItems}}" wx:key="id">
          <view class="goods-info">
            <view class="goods-name">{{item.couponName}}</view>
            <view class="goods-detail">
              <view class="goods-quantity">数量: {{item.quantity}}</view>
              <view class="goods-price">¥{{item.finalPrice}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 物流信息 -->
    <view class="logistics-card" wx:if="{{order.status === 'SHIPPED' && logisticsInfo}}">
      <view class="logistics-header">
        <view class="logistics-title">物流信息</view>
      </view>
      <view class="logistics-content">
        <view class="logistics-company">
          <view class="company-name">{{logisticsInfo.company}}</view>
          <view class="logistics-no">{{logisticsInfo.trackingNo}}</view>
        </view>
        <view class="logistics-timeline">
          <view class="timeline-item" wx:for="{{logisticsInfo.tracks}}" wx:key="time">
            <view class="timeline-dot"></view>
            <view class="timeline-content">
              <view class="timeline-desc">{{item.description}}</view>
              <view class="timeline-time">{{formatDate(item.time)}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 订单操作 -->
    <view class="order-actions-card">
      <view class="actions-title">订单操作</view>
      <view class="actions-list">
        <button
          wx:if="{{order.status === 'PENDING'}}"
          class="action-btn cancel"
          bindtap="cancelOrder"
        >
          取消订单
        </button>

        <button
          wx:if="{{order.status === 'SHIPPED'}}"
          class="action-btn confirm"
          bindtap="confirmDelivery"
        >
          确认收货
        </button>

        <button
          wx:if="{{order.status === 'DELIVERED'}}"
          class="action-btn refund"
          bindtap="requestRefund"
        >
          申请退款
        </button>
      </view>
    </view>
  </view>
</view>
