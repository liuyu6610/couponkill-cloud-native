<view class="page" wx:if="{{order}}">
  <view class="title">订单详情</view>
  <view class="row">订单号：{{order.id}}</view>
  <view class="row">用户ID：{{order.userId}}</view>
  <view class="row">券ID：{{order.couponId}}</view>
  <view class="row">状态：{{statusText}}</view>
  <view class="row">领取时间：{{order.getTime || '-'}}</view>
  <button wx:if="{{order.status==1}}" type="warn" bindtap="cancelOrder">取消订单</button>
</view>
<view wx:if="{{isLoading}}" class="hint">加载中...</view>
<view wx:if="{{!isLoading && !order}}" class="hint">未找到订单（仅可查最近一页）</view>
