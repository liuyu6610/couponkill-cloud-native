<!--pages/login/index.wxml — 账号密码登录（对齐 /api/v1/user/login）-->
<view class="page-container">
  <view class="login-container">
    <view class="login-logo">
      <view class="logo-icon">🎫</view>
      <view class="logo-text">CouponKill</view>
      <view class="logo-subtitle">云原生秒杀 · 现网契约</view>
    </view>

    <view class="login-form">
      <input
        class="input"
        placeholder="用户名"
        value="{{username}}"
        bindinput="onUsername"
      />
      <input
        class="input"
        password
        placeholder="密码"
        value="{{password}}"
        bindinput="onPassword"
      />
      <button
        class="btn-login {{isLoading ? 'loading' : ''}}"
        bindtap="doLogin"
        disabled="{{isLoading}}"
      >
        {{isLoading ? '登录中...' : '登录'}}
      </button>
      <view class="link" bindtap="goRegister">没有账号？去注册</view>
      <view class="hint">演示账号 demo / demo1234</view>
    </view>
  </view>
</view>
