.page-container {
  min-height: 100vh;
  padding: 80rpx 48rpx;
  background: linear-gradient(160deg, #fff5f5 0%, #ffffff 55%);
  box-sizing: border-box;
}

.login-logo {
  text-align: center;
  margin-bottom: 64rpx;
}

.logo-icon {
  font-size: 96rpx;
}

.logo-text {
  font-size: 48rpx;
  font-weight: 700;
  margin-top: 16rpx;
}

.logo-subtitle {
  color: #888;
  margin-top: 8rpx;
  font-size: 26rpx;
}

.login-form .input {
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  font-size: 30rpx;
}

.btn-login {
  margin-top: 16rpx;
  background: #ff4757;
  color: #fff;
  border-radius: 12rpx;
}

.btn-login[disabled] {
  opacity: 0.7;
}

.link {
  margin-top: 32rpx;
  text-align: center;
  color: #ff4757;
  font-size: 28rpx;
}

.hint {
  margin-top: 24rpx;
  text-align: center;
  color: #999;
  font-size: 24rpx;
}
