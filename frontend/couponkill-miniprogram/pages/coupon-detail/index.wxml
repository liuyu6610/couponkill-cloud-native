<view class="page" wx:if="{{coupon}}">
  <view class="name">{{coupon.name}}</view>
  <view class="desc">{{coupon.description || '暂无描述'}}</view>
  <view class="row">面值：¥{{coupon.faceValue}}</view>
  <view class="row">门槛：满 ¥{{coupon.minSpend}}</view>
  <view class="row" wx:if="{{isSeckill}}">秒杀库存：{{coupon.seckillRemainingStock}}</view>
  <view class="row" wx:else>库存：{{coupon.remainingStock}}</view>
  <view class="row" wx:if="{{isSeckill}}">{{countdown}}</view>

  <button wx:if="{{isSeckill}}" type="warn" bindtap="seckillNow" disabled="{{!canBuy}}">立即秒杀</button>
  <button wx:else type="primary" bindtap="buyNow" disabled="{{!canBuy}}">立即领取</button>
</view>
<view wx:if="{{isLoading}}" class="hint">加载中...</view>
