<view class="page">
  <view class="hero">
    <view class="title">CouponKill</view>
    <view class="sub">现网契约 · 可用券 / 秒杀券</view>
    <view class="actions">
      <button size="mini" bindtap="goToCoupons">全部优惠券</button>
      <button size="mini" type="warn" bindtap="goToSeckill">秒杀专区</button>
    </view>
  </view>

  <view class="section">
    <view class="section-title">秒杀精选</view>
    <view wx:if="{{isLoading}}" class="hint">加载中...</view>
    <block wx:for="{{seckillCoupons}}" wx:key="id">
      <view class="card" data-id="{{item.id}}" bindtap="goToCouponDetail">
        <view class="name">{{item.name}}</view>
        <view class="meta">面值 ¥{{item.faceValue}} · 库存 {{item.seckillRemainingStock}}</view>
      </view>
    </block>
    <view wx:if="{{!isLoading && seckillCoupons.length===0}}" class="hint">暂无秒杀券</view>
  </view>

  <view class="section">
    <view class="section-title">常驻优惠券</view>
    <block wx:for="{{hotCoupons}}" wx:key="id">
      <view class="card" data-id="{{item.id}}" bindtap="goToCouponDetail">
        <view class="name">{{item.name}}</view>
        <view class="meta">面值 ¥{{item.faceValue}} · 库存 {{item.remainingStock}}</view>
        <button size="mini" catchtap="buyNow" data-id="{{item.id}}">领取</button>
      </view>
    </block>
    <view wx:if="{{!isLoading && hotCoupons.length===0}}" class="hint">暂无常驻券</view>
  </view>
</view>
