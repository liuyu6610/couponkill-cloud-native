.page { padding: 24rpx; }
.hero { padding: 32rpx; background: #fff5f5; border-radius: 16rpx; margin-bottom: 24rpx; }
.title { font-size: 40rpx; font-weight: 700; }
.sub { color: #888; margin: 8rpx 0 20rpx; font-size: 24rpx; }
.actions button { margin-right: 16rpx; }
.section { margin-bottom: 32rpx; }
.section-title { font-weight: 600; margin-bottom: 16rpx; }
.card {
  background: #fff;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.name { font-size: 30rpx; font-weight: 600; }
.meta { color: #666; font-size: 24rpx; margin: 8rpx 0; }
.hint { color: #999; font-size: 26rpx; padding: 16rpx 0; }
