/* app.wxss */
/* 全局样式 */
.container {
  padding: 20rpx;
}

.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 按钮样式 */
.btn-primary {
  background-color: #ff4757;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 24rpx 32rpx;
}

.btn-primary:active {
  background-color: #ff3742;
}

.btn-secondary {
  background-color: #fff;
  color: #333;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 24rpx 32rpx;
}

.btn-secondary:active {
  background-color: #f5f5f5;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-primary {
  background-color: #e3f2fd;
  color: #1976d2;
}

.tag-success {
  background-color: #e8f5e8;
  color: #4caf50;
}

.tag-warning {
  background-color: #fff3e0;
  color: #ff9800;
}

.tag-danger {
  background-color: #ffebee;
  color: #f44336;
}

/* 优惠券卡片样式 */
.coupon-card {
  background: linear-gradient(135deg, #ff4757, #ff6b7a);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.coupon-card::before {
  content: '';
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 20rpx;
  background: repeating-linear-gradient(
    0deg,
    #fff 0rpx,
    #fff 20rpx,
    transparent 20rpx,
    transparent 40rpx
  );
}

.coupon-card .coupon-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.coupon-card .coupon-value {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.coupon-card .coupon-desc {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 秒杀样式 */
.seckill-badge {
  background-color: #ff4757;
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  position: absolute;
  top: 20rpx;
  right: 20rpx;
}

.countdown {
  background-color: #333;
  color: #fff;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-family: 'Courier New', monospace;
  font-size: 28rpx;
  font-weight: bold;
}

/* 加载动画 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #ff4757;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 空状态 */
.empty-container {
  text-align: center;
  padding: 120rpx 40rpx;
  color: #999;
}

.empty-image {
  width: 240rpx;
  height: 160rpx;
  margin-bottom: 40rpx;
  opacity: 0.5;
}

/* 分页样式 */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

.page-btn {
  padding: 16rpx 24rpx;
  margin: 0 8rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  background: #fff;
  color: #333;
}

.page-btn.active {
  background: #ff4757;
  color: #fff;
  border-color: #ff4757;
}

.page-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 40rpx 30rpx;
  max-height: 80vh;
  overflow-y: auto;
}

/* 导航栏样式 */
.navbar {
  background: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.navbar-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

/* 搜索框样式 */
.search-bar {
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
  margin: 20rpx 0;
}

.search-input {
  background: transparent;
  border: none;
  outline: none;
  font-size: 28rpx;
  color: #333;
}

/* 商品列表网格 */
.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 20rpx 0;
}

/* 价格样式 */
.price {
  color: #ff4757;
  font-size: 36rpx;
  font-weight: bold;
}

.price-original {
  color: #999;
  font-size: 24rpx;
  text-decoration: line-through;
  margin-left: 12rpx;
}

/* 标签栏样式 */
.tab-bar {
  background: #fff;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  display: inline-block;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s;
}

.tab-item.active {
  color: #ff4757;
  border-bottom-color: #ff4757;
  font-weight: bold;
}

/* 订单状态样式 */
.status-pending {
  color: #ff9800;
}

.status-paid {
  color: #2196f3;
}

.status-shipped {
  color: #9c27b0;
}

.status-delivered {
  color: #4caf50;
}

.status-cancelled {
  color: #f44336;
}

/* 通用间距 */
.margin-t-20 { margin-top: 20rpx; }
.margin-b-20 { margin-bottom: 20rpx; }
.margin-l-20 { margin-left: 20rpx; }
.margin-r-20 { margin-right: 20rpx; }

.padding-20 { padding: 20rpx; }
.padding-30 { padding: 30rpx; }

/* 文本溢出处理 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
